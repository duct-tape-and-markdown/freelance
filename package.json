{
  "name": "freelance-mcp",
  "version": "1.2.1",
  "mcpName": "io.github.duct-tape-and-markdown/freelance",
  "type": "module",
  "sideEffects": false,
  "description": "Graph-based workflow enforcement for AI coding agents",
  "main": "dist/index.js",
  "bin": {
    "freelance": "dist/bin.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./state": {
      "types": "./dist/state/index.d.ts",
      "import": "./dist/state/index.js"
    },
    "./memory": {
      "types": "./dist/memory/index.d.ts",
      "import": "./dist/memory/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "files": [
    "dist/",
    "src/",
    "templates/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/bin.ts",
    "test": "vitest run",
    "sync-plugin-version": "node scripts/sync-plugin-version.mjs",
    "version": "npm run sync-plugin-version && git add plugins/freelance/.claude-plugin/plugin.json",
    "prepublishOnly": "npm run sync-plugin-version && npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "workflow",
    "graph",
    "ai",
    "agent",
    "claude",
    "cursor",
    "automation"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/duct-tape-and-markdown/freelance.git"
  },
  "homepage": "https://github.com/duct-tape-and-markdown/freelance#readme",
  "bugs": {
    "url": "https://github.com/duct-tape-and-markdown/freelance/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@dagrejs/graphlib": "^4.0.1",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.0",
    "picomatch": "^4.0.4",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  },
  "optionalDependencies": {
    "@inquirer/prompts": "^8.3.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/picomatch": "^4.0.3",
    "@vitest/coverage-v8": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
