{
  "name": "freelance-mcp",
  "version": "1.4.1",
  "mcpName": "io.github.duct-tape-and-markdown/freelance",
  "type": "module",
  "sideEffects": false,
  "description": "Graph-based workflow enforcement for AI coding agents",
  "main": "dist/index.js",
  "bin": {
    "freelance": "dist/bin.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "src/",
    "templates/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/bin.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check": "biome check",
    "check:fix": "biome check --write",
    "prepare": "simple-git-hooks || true",
    "sync-plugin-version": "node scripts/sync-plugin-version.mjs",
    "version": "npm run sync-plugin-version && git add plugins/freelance/.claude-plugin/plugin.json",
    "prepublishOnly": "npm run sync-plugin-version && npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "workflow",
    "graph",
    "ai",
    "agent",
    "claude",
    "cursor",
    "automation"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/duct-tape-and-markdown/freelance.git"
  },
  "homepage": "https://github.com/duct-tape-and-markdown/freelance#readme",
  "bugs": {
    "url": "https://github.com/duct-tape-and-markdown/freelance/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@dagrejs/graphlib": "^4.0.1",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@inquirer/prompts": "^8.3.2"
  },
  "simple-git-hooks": {
    "pre-commit": "npx biome check --no-errors-on-unmatched"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/js-yaml": "^4.0.9",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "simple-git-hooks": "2.13.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
