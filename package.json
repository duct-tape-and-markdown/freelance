{
  "name": "freelance-mcp",
  "version": "1.1.0",
  "type": "module",
  "description": "Graph-based workflow enforcement for AI coding agents",
  "main": "dist/index.js",
  "bin": {
    "freelance": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./state": {
      "types": "./dist/state/index.d.ts",
      "import": "./dist/state/index.js"
    },
    "./memory": {
      "types": "./dist/memory/index.d.ts",
      "import": "./dist/memory/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "files": [
    "dist/",
    "templates/",
    "!dist/**/*.js.map",
    "!dist/**/*.d.ts.map"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "workflow",
    "graph",
    "ai",
    "agent",
    "claude",
    "cursor",
    "automation"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/duct-tape-and-markdown/freelance.git"
  },
  "homepage": "https://github.com/duct-tape-and-markdown/freelance#readme",
  "bugs": {
    "url": "https://github.com/duct-tape-and-markdown/freelance/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@dagrejs/graphlib": "^4.0.1",
    "@inquirer/prompts": "^8.3.2",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.0",
    "picomatch": "^4.0.4",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  },
  "peerDependencies": {
    "better-sqlite3": ">=9"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/picomatch": "^4.0.3",
    "@vitest/coverage-v8": "^4.1.0",
    "better-sqlite3": "^12.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
